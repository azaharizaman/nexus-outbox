{
    "name": "azaharizaman/nexus-outbox",
    "description": "Transactional outbox domain model and publish lifecycle (Layer 1).",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "psr/clock": "^1.0",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Nexus\\Outbox\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nexus\\Outbox\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
